{
  "name": "my-company-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "dev:services": "pnpm -F api-gateway dev & pnpm -F service-doctors dev & pnpm -F service-services dev & pnpm -F service-auth dev",
    "build:all": "pnpm -F shared-types build && pnpm -F api-gateway build && pnpm -F service-doctors build && pnpm -F service-services build && pnpm -F service-auth build && next build",
    "start:gateway": "pnpm -F api-gateway start",
    "start:doctors": "pnpm -F service-doctors start",
    "start:services": "pnpm -F service-services start",
    "start:auth": "pnpm -F service-auth start"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.5.1",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@supabase/supabase-js": "^2.103.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "swiper": "^12.1.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
